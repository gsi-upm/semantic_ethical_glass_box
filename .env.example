# AMOR-SEGB / SEGB example environment file
#
# Minimal setup for centralized docker-compose deployment:
#   cp .env.example .env
#
# Required by Virtuoso + backend startup.
VIRTUOSO_PASSWORD=change-this-password

# Optional: enable backend JWT auth.
# - Set non-empty SECRET_KEY => auth enabled (roles enforced).
# - Empty/unset SECRET_KEY => auth disabled.
# SECRET_KEY=change-me

# Optional Virtuoso overrides (defaults are usually enough).
# VIRTUOSO_ENDPOINT=http://amor-segb-virtuoso:8890/sparql-auth
# VIRTUOSO_GRAPH_URI=http://amor-segb/events
# VIRTUOSO_USER=dba

# Optional: image registry overrides for production compose.
# Defaults point to GHCR images linked to gsi-upm/semantic_ethical_glass_box.
# SEGB_BACKEND_IMAGE=ghcr.io/gsi-upm/semantic_ethical_glass_box/amor-segb
# SEGB_FRONTEND_IMAGE=ghcr.io/gsi-upm/semantic_ethical_glass_box/segb-ui
# SEGB_IMAGE_TAG=latest
