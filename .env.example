# AMOR-SEGB / SEGB example environment file
#
# Optional: copy to `.env` to override docker-compose defaults:
#   cp .env.example .env
#
# Notes:
# - Values here are intended for local development/demo only.
# - Do not commit real secrets into `.env`.
#

# Virtuoso SPARQL endpoint (as seen from the backend container).
# - Docker Compose (recommended): keep the service hostname.
# - Backend running on host: use http://localhost:8890/sparql-auth
VIRTUOSO_ENDPOINT=http://amor-segb-virtuoso:8890/sparql-auth

# Named graph where SEGB triples are inserted.
VIRTUOSO_GRAPH_URI=http://amor-segb/events

# Virtuoso credentials (default demo user is `dba`).
VIRTUOSO_USER=dba
VIRTUOSO_PASSWORD=change-this-password

# Backend authentication mode:
# - Set SECRET_KEY (non-empty): JWT auth ENABLED.
# - Empty/unset SECRET_KEY: JWT auth DISABLED (every request is treated as all roles: admin+logger+auditor).
# SECRET_KEY=change-me

# Optional: backend version string (also shown in OpenAPI docs).
# VERSION=dev

# Optional: override OpenAPI metadata files.
# API_INFO_FILE_PATH=./apps/backend/api_info/segb/api_info.json
# API_DESCRIPTION_FILE_PATH=./apps/backend/api_info/segb/api_description.md

# Optional: backend server log file name and severity.
# The file is stored under /logs and shown in the UI page `/system/logs` (admin role).
# SERVER_LOG_FILE=segb.log
# SERVER_LOG_DIR=/logs
# LOGGING_LEVEL=INFO

# Optional: shared-context resolver tuning (only relevant if you use `/shared-context/*` endpoints).
# SHARED_CONTEXT_NAMESPACE=https://gsi.upm.es/segb/shared-events/
# SHARED_CONTEXT_TIME_WINDOW_SECONDS=3.0
# SHARED_CONTEXT_MATCH_THRESHOLD=0.85
# SHARED_CONTEXT_AMBIGUOUS_THRESHOLD=0.70
# SHARED_CONTEXT_CLOSE_MARGIN=0.05

# NOTE ABOUT ROBOT RUNTIME:
# This `.env` file is for the centralized deployment (backend/web/virtuoso) only.
# `semantic_log_generator` running on robots DOES NOT auto-read these variables.
# Robot-side shared-context resolver configuration must be done in robot deployment/runtime code.
